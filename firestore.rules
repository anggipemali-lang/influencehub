rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.role != 'admin';
      allow create: if isOwner(userId) && request.resource.data.role in ['brand', 'influencer'];
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid']);
    }

    // Influencer Details
    match /influencerDetails/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.brandId == request.auth.uid;
    }

    // Offers
    match /offers/{offerId} {
      allow read: if isSignedIn() && (resource.data.brandId == request.auth.uid || resource.data.influencerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.brandId == request.auth.uid || resource.data.influencerId == request.auth.uid);
    }
  }
}
